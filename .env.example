# === PDF Service — Variáveis de ambiente ===

# URL base da API compatível com OpenAI (Chat Completions), sem barra final opcional.
# Ollama local (padrão): http://127.0.0.1:11434/v1
# LM Studio: http://127.0.0.1:1234/v1
# Docker Compose (serviço interno): http://ollama:11434/v1
LLM_API_BASE=http://127.0.0.1:11434/v1

# Nome do modelo carregado no runtime local
LLM_MODEL=qwen2.5:0.5b

# Opcional: Bearer se o servidor exigir (maioria dos hosts locais deixa vazio)
LLM_API_KEY=

# Timeout HTTP para o LLM (segundos) — fase de leitura da resposta
LLM_TIMEOUT=600

# Timeout de conexão TCP ao host do LLM (segundos); falha rápido se nada escuta na porta
LLM_CONNECT_TIMEOUT=12

# Máximo de tokens na resposta do modelo
LLM_MAX_TOKENS=4000

# 1 = tentar response_format json_object; 0 = desligar (backends que não suportam)
LLM_JSON_MODE=1

# Tamanho máximo do arquivo PDF (MB)
MAX_FILE_SIZE_MB=15

# Máximo de caracteres do PDF numa leitura única (acima: início+fim ou multi-trechos)
MAX_TEXT_CHARS=22000

# Pipeline multi-trecho (PDFs longos)
LLM_CHUNK_SIZE=9000
LLM_CHUNK_OVERLAP=350
LLM_MAX_CHUNKS=8
LLM_HEAD_TAIL_FACTOR=2.25

# Porta da aplicação Flask (desenvolvimento)
PORT=8080

# --- Logs da aplicação (pasta dedicada) ---
# Vazio = pasta `logs/` na raiz do repositório. Relativo (ex.: logs ou data/app-logs) =
# sempre em relação à raiz do projeto, NÃO ao diretório de trabalho atual.
# LOG_DIR=. ou a própria raiz do repo é tratado como `logs/` (nunca escrever .log na raiz).
# LOG_DIR=logs

# 1 = escrever também em ficheiro (RotatingFileHandler); 0 = só consola
LOG_TO_FILE=1
# Apenas o nome do ficheiro (path com ../ é ignorado; o ficheiro fica sempre dentro de LOG_DIR)
LOG_FILE_NAME=pdf-service.log
# Tamanho máximo de cada ficheiro antes de rodar (bytes) e número de backups
# LOG_FILE_MAX_BYTES=5242880
# LOG_FILE_BACKUP_COUNT=5
