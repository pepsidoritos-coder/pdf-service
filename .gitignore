# Logs da aplicação — ignorar conteúdo de logs/, mas manter logs/.gitkeep versionado
# (não usar só `logs/**`: isso ignora o diretório e o `!` do .gitkeep deixa de funcionar)
/*.log
/logs/*
!/logs/.gitkeep

